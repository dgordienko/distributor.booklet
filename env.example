# Copy to .env at the repo root, fill in real values, then run:
#   docker compose up -d --build

# Auth0 — baked into the admin-web JS bundle at image build time (Vite
# inlines VITE_* at build, not at container start), so changing these
# requires rebuilding the admin image.
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=<auth0-spa-client-id>

# Backend: external devices API used by the "sync teams" button. Falls back
# to the built-in default (see backend/src/services/teams.service.ts) if unset.
DEVICES_API_URL=http://<devices-api-host>:8089/api/devices

# Ports published on the host.
ADMIN_PORT=8080
BACKEND_PORT=4000
